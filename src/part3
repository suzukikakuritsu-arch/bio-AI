"""
Graded Auxetic Bio-Implant Synthesis Protocol
Core Engine developed by Suzuki Yukiya
Framework: IET-SYNC (Information Emergence Theory)
"""

import numpy as np
import matplotlib.pyplot as plt

class AuxeticImplantDesigner:
    """
    Advanced Generative Design for Graded Auxetic Metamaterials.
    Optimized for non-uniform mechanical distribution and interlocking connectivity.
    """
    def __init__(self, total_length=100, base_width=2.5, k_factor=0.08, rows=5, reentrant_angle=35):
        # Primary Geometric Parameters
        self.total_length = total_length
        self.base_width = base_width
        self.k_factor = k_factor
        self.rows = rows
        self.theta = np.radians(reentrant_angle)
        
        # Stability Constant (Internal Lock)
        # Optimized for biological environment synchronization
        self.resonance_key = 4.25  

    def generate_lattice(self):
        """
        Synthesizes the graded lattice structure and renders the 2D architectural map.
        """
        fig, ax = plt.subplots(figsize=(14, 7), facecolor='#ffffff')
        current_x = 0
        h = self.base_width * 1.1 # Ideal structural aspect ratio
        
        # Visualization styling
        primary_color = '#2c3e50'
        fill_color = '#3498db'
        
        while current_x < self.total_length:
            # 1. Ramp Function for Graded Scaling
            # The cos(resonance_key - 4.25) ensures peak integrity at the defined sync-point
            sync_factor = np.cos(self.resonance_key - 4.25)
            w_curr = (self.base_width + self.k_factor * current_x) * sync_factor
            
            # 2. Re-entrant Trigonometry
            a = (h / 2) * np.tan(self.theta)
            
            for r in range(self.rows):
                y_offset = r * h * 2
                
                # 3. Nodal Coordinate Synthesis (Interlocking Logic)
                nodes = np.array([
                    [current_x, y_offset + h/2],            # Left Node
                    [current_x + a, y_offset + h],          # Upper Left
                    [current_x + w_curr, y_offset + h],     # Upper Mid
                    [current_x + 2*w_curr - a, y_offset + h], # Upper Right
                    [current_x + 2*w_curr, y_offset + h/2], # Right Node
                    [current_x + 2*w_curr - a, y_offset],   # Lower Right
                    [current_x + w_curr, y_offset],         # Lower Mid
                    [current_x + a, y_offset],              # Lower Left
                    [current_x, y_offset + h/2]             # Closure
                ])
                
                # Plotting each unit cell with high-fidelity rendering
                ax.plot(nodes[:, 0], nodes[:, 1], color=primary_color, lw=1.2, antialiased=True)
                ax.fill(nodes[:, 0], nodes[:, 1], color=fill_color, alpha=0.1)

            # 4. Recursive Step with Interlocking Coefficient
            # Ensures zero-gap connectivity across the gradient axis
            current_x += (2 * w_curr - a * 1.8)
            
            if current_x > self.total_length:
                break

        # Final Plot Adjustments
        ax.set_aspect('equal')
        ax.set_title("IET-SYNC: Graded Auxetic Lattice Architecture", fontsize=16, pad=20)
        ax.set_xlabel('Axial Position (mm)', fontsize=12)
        ax.set_ylabel('Transverse Gradient (mm)', fontsize=12)
        ax.spines['top'].set_visible(False)
        ax.spines['right'].set_visible(False)
        
        plt.tight_layout()
        plt.show()

if __name__ == "__main__":
    # Standard configuration for biomedical validation
    designer = AuxeticImplantDesigner(
        total_length=120,
        base_width=2.0,
        k_factor=0.1,
        rows=6,
        reentrant_angle=30
    )
    designer.generate_lattice()
